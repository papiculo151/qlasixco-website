<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QlaSixco Restaurant — Borneo • Western • Seafood</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Bebas+Neue&family=Crimson+Pro:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --black: #0A0805;
    --deep: #0e0b07;
    --cream: #F5EDD8;
    --warm: #1A1410;
    --text: #D4C5A9;
    --accent: #8B1A1A;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body {
    background: var(--black);
    color: var(--text);
    font-family: 'Crimson Pro', Georgia, serif;
    overflow-x: hidden;
  }

/* NAV */
nav {
position: fixed;
top:0; left:0; right:0;
z-index: 100;
display: flex;
justify-content: space-between;
align-items: center;
padding: 1.4rem 3.5rem;
transition: background 0.4s, border 0.4s;
}
nav.scrolled {
background: rgba(10,8,5,0.97);
border-bottom: 1px solid rgba(201,168,76,0.18);
backdrop-filter: blur(10px);
}
.nav-logo {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.8rem;
letter-spacing: 0.15em;
color: var(–gold);
}
.nav-logo span { color: var(–cream); }
.nav-links {
display: flex;
gap: 2.2rem;
list-style: none;
}
.nav-links a {
font-family: ‘Crimson Pro’, serif;
font-size: 0.9rem;
letter-spacing: 0.12em;
color: var(–text);
text-decoration: none;
text-transform: uppercase;
transition: color 0.3s;
position: relative;
}
.nav-links a::after {
content:’’;
position:absolute;
bottom:-4px; left:0; right:0;
height:1px;
background: var(–gold);
transform: scaleX(0);
transition: transform 0.3s;
}
.nav-links a:hover { color: var(–gold); }
.nav-links a:hover::after { transform: scaleX(1); }
.nav-cta {
background: var(–gold) !important;
color: var(–black) !important;
padding: 0.55rem 1.4rem;
font-weight: 700;
}
.nav-cta::after { display:none !important; }
.nav-cta:hover { background: var(–gold-light) !important; }

/* HERO */
.hero {
min-height: 100vh;
position: relative;
display: flex;
align-items: center;
justify-content: center;
overflow: hidden;
}
.hero-bg-img {
position: absolute;
inset: 0;
background-image: url(‘data:image/jpeg;base64,’);
background-size: cover;
background-position: center 30%;
filter: brightness(0.35) saturate(0.8);
transform: scale(1.05);
animation: slowZoom 20s ease-in-out infinite alternate;
}
@keyframes slowZoom {
from { transform: scale(1.05); }
to { transform: scale(1.12); }
}
.hero-overlay {
position: absolute;
inset: 0;
background:
linear-gradient(to bottom, rgba(10,8,5,0.5) 0%, rgba(10,8,5,0.1) 40%, rgba(10,8,5,0.1) 60%, rgba(10,8,5,0.9) 100%),
radial-gradient(ellipse at 50% 50%, rgba(201,168,76,0.04) 0%, transparent 70%);
}
.hero-content {
position: relative;
z-index: 2;
text-align: center;
padding: 2rem;
animation: fadeUp 1.4s ease-out both;
}
@keyframes fadeUp {
from { opacity:0; transform: translateY(40px); }
to { opacity:1; transform: translateY(0); }
}
.hero-tag {
font-size: 0.75rem;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(–gold);
display: block;
margin-bottom: 1.5rem;
animation: fadeUp 1.4s 0.2s ease-out both;
}
.hero-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: clamp(5rem, 16vw, 13rem);
line-height: 0.88;
letter-spacing: 0.04em;
color: var(–cream);
margin-bottom: 0.6rem;
text-shadow: 0 4px 40px rgba(0,0,0,0.8);
animation: fadeUp 1.4s 0.3s ease-out both;
}
.hero-title span { color: var(–gold); }
.hero-subtitle {
font-family: ‘Cormorant Garamond’, serif;
font-size: clamp(1rem, 2.2vw, 1.5rem);
font-style: italic;
letter-spacing: 0.18em;
color: rgba(245,237,216,0.75);
margin-bottom: 0.8rem;
animation: fadeUp 1.4s 0.45s ease-out both;
}
.hero-cuisine-pills {
display: flex;
gap: 0.8rem;
justify-content: center;
flex-wrap: wrap;
margin-bottom: 2.5rem;
animation: fadeUp 1.4s 0.55s ease-out both;
}
.pill {
font-size: 0.72rem;
letter-spacing: 0.25em;
text-transform: uppercase;
color: rgba(201,168,76,0.85);
border: 1px solid rgba(201,168,76,0.35);
padding: 0.35rem 1rem;
backdrop-filter: blur(4px);
background: rgba(10,8,5,0.3);
}
.hero-divider {
display: flex;
align-items: center;
justify-content: center;
gap: 1rem;
margin-bottom: 2.5rem;
animation: fadeUp 1.4s 0.6s ease-out both;
}
.hero-divider::before, .hero-divider::after {
content:’’;
width:70px; height:1px;
background: linear-gradient(to right, transparent, rgba(201,168,76,0.7));
}
.hero-divider::after { background: linear-gradient(to left, transparent, rgba(201,168,76,0.7)); }
.gem { width:6px; height:6px; background:var(–gold); transform:rotate(45deg); }
.hero-btns {
display: flex;
gap: 1.2rem;
justify-content: center;
flex-wrap: wrap;
animation: fadeUp 1.4s 0.7s ease-out both;
}
.btn-primary {
background: var(–gold);
color: var(–black);
padding: 1rem 2.6rem;
font-family: ‘Crimson Pro’, serif;
font-size: 1rem;
font-weight: 700;
letter-spacing: 0.12em;
text-transform: uppercase;
text-decoration: none;
border: none;
cursor: pointer;
transition: all 0.3s;
display: inline-block;
}
.btn-primary:hover { background: var(–gold-light); transform: translateY(-2px); }
.btn-outline {
background: transparent;
color: var(–cream);
padding: 1rem 2.4rem;
font-family: ‘Crimson Pro’, serif;
font-size: 1rem;
letter-spacing: 0.12em;
text-transform: uppercase;
text-decoration: none;
border: 1px solid rgba(245,237,216,0.45);
cursor: pointer;
transition: all 0.3s;
display: inline-block;
backdrop-filter: blur(4px);
}
.btn-outline:hover { border-color: var(–gold); color: var(–gold); }
.hero-scroll {
position: absolute;
bottom: 2.5rem; left: 50%;
transform: translateX(-50%);
display: flex;
flex-direction: column;
align-items: center;
gap: 0.5rem;
color: rgba(201,168,76,0.5);
font-size: 0.65rem;
letter-spacing: 0.25em;
text-transform: uppercase;
animation: fadeUp 2s 1.2s ease-out both;
}
.scroll-line {
width:1px; height:45px;
background: linear-gradient(to bottom, var(–gold), transparent);
animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
0%,100% { opacity:1; transform:scaleY(1); }
50% { opacity:0.3; transform:scaleY(0.5); }
}

/* SECTION COMMONS */
.section-inner { max-width:1180px; margin:0 auto; padding:0 2rem; }
.section-label {
font-size: 0.68rem;
letter-spacing: 0.4em;
text-transform: uppercase;
color: var(–gold);
display: block;
margin-bottom: 0.9rem;
}
.section-title {
font-family: ‘Playfair Display’, serif;
font-size: clamp(2rem, 4.5vw, 3.6rem);
font-weight: 700;
color: var(–cream);
line-height: 1.1;
}
.section-title em { font-style:italic; color:var(–gold); }

/* ABOUT */
.about {
padding: 8rem 0;
background: var(–deep);
position: relative;
overflow: hidden;
}
.about-bg-img {
position: absolute;
right: -5%;
top: 0; bottom: 0;
width: 45%;
background-image: url(‘data:image/jpeg;base64,’);
background-size: cover;
background-position: center top;
filter: brightness(0.18) saturate(0.5);
mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.8) 40%, black 100%);
-webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.8) 40%, black 100%);
}
.about-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 5rem;
align-items: center;
position: relative;
z-index: 2;
}
.about-text p {
font-size: 1.13rem;
line-height: 1.9;
color: rgba(212,197,169,0.8);
margin-bottom: 1.4rem;
}
.about-text p strong { color: var(–gold); font-weight:600; }
.about-card {
background: rgba(26,20,16,0.85);
border: 1px solid rgba(201,168,76,0.18);
padding: 2.8rem;
backdrop-filter: blur(8px);
position: relative;
}
.about-card::before {
content:’’;
position:absolute;
top:-1px; left:-1px; right:-1px; bottom:-1px;
background: linear-gradient(135deg, rgba(201,168,76,0.25), transparent 40%, transparent 60%, rgba(201,168,76,0.08));
pointer-events:none;
}
.about-quote {
font-family: ‘Cormorant Garamond’, serif;
font-size: 1.25rem;
font-style: italic;
color: var(–cream);
line-height: 1.7;
margin-bottom: 2rem;
padding-bottom: 2rem;
border-bottom: 1px solid rgba(201,168,76,0.15);
}
.stat-row {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 1.5rem;
}
.stat {
text-align:center;
padding:1.3rem;
border: 1px solid rgba(201,168,76,0.1);
background: rgba(10,8,5,0.3);
}
.stat-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 2.6rem;
color: var(–gold);
display: block;
line-height:1;
}
.stat-label {
font-size: 0.72rem;
letter-spacing: 0.15em;
text-transform: uppercase;
color: rgba(212,197,169,0.55);
margin-top: 0.3rem;
display:block;
}

/* CUISINE */
.cuisine {
padding: 7rem 0;
background: var(–black);
position: relative;
overflow: hidden;
}
.cuisine-bg {
position: absolute;
inset: 0;
background-image: url(‘data:image/jpeg;base64,’);
background-size: cover;
background-position: center;
filter: brightness(0.08) saturate(0.3);
opacity: 0.6;
}
.cuisine-intro { max-width:580px; margin-bottom:3.5rem; position:relative; z-index:2; }
.cuisine-cards {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1px;
background: rgba(201,168,76,0.1);
position: relative;
z-index:2;
}
.cuisine-card {
background: rgba(14,11,7,0.95);
padding: 3rem 2.2rem;
position:relative;
overflow:hidden;
transition: all 0.4s;
backdrop-filter: blur(4px);
}
.cuisine-card::before {
content:’’;
position:absolute;
bottom:0; left:0; right:0;
height:3px;
background: var(–gold);
transform: scaleX(0);
transition: transform 0.4s;
}
.cuisine-card:hover { background: rgba(26,20,16,0.98); }
.cuisine-card:hover::before { transform: scaleX(1); }
.cuisine-icon { font-size:2.4rem; margin-bottom:1.3rem; display:block; }
.cuisine-name {
font-family: ‘Playfair Display’, serif;
font-size: 1.5rem;
color: var(–cream);
margin-bottom: 0.9rem;
font-weight:700;
}
.cuisine-desc { font-size:0.97rem; line-height:1.7; color:rgba(212,197,169,0.6); }
.cuisine-num {
position:absolute; top:2rem; right:1.8rem;
font-family: ‘Bebas Neue’, sans-serif;
font-size:4rem;
color:rgba(201,168,76,0.05);
line-height:1;
}

/* MENU */
.menu {
padding: 8rem 0;
background: var(–deep);
position:relative;
overflow:hidden;
}
.menu-bg {
position:absolute;
inset:0;
background-image: url(‘data:image/jpeg;base64,’);
background-size: cover;
background-position: center 20%;
filter: brightness(0.07) saturate(0.2);
opacity:0.5;
}
.menu-header {
display:flex;
justify-content:space-between;
align-items:flex-end;
margin-bottom:3.5rem;
position:relative; z-index:2;
}
.menu-grid {
display:grid;
grid-template-columns: repeat(2,1fr);
gap:1px;
background: rgba(201,168,76,0.08);
position:relative; z-index:2;
}
.menu-item {
background: rgba(10,8,5,0.92);
padding: 2.2rem;
display:flex;
gap:1.3rem;
transition: background 0.3s;
position:relative;
overflow:hidden;
backdrop-filter: blur(4px);
}
.menu-item:hover { background: rgba(26,20,16,0.97); }
.menu-emoji { font-size:2.3rem; flex-shrink:0; margin-top:0.1rem; }
.menu-info { flex:1; }
.menu-name {
font-family:‘Playfair Display’,serif;
font-size:1.2rem;
color:var(–cream);
margin-bottom:0.35rem;
font-weight:700;
}
.menu-desc { font-size:0.92rem; line-height:1.6; color:rgba(212,197,169,0.58); margin-bottom:0.7rem; }
.menu-tag {
display:inline-block;
font-size:0.62rem;
letter-spacing:0.15em;
text-transform:uppercase;
color:var(–gold);
border:1px solid rgba(201,168,76,0.3);
padding:0.2rem 0.55rem;
margin-right:0.4rem;
}
.menu-featured {
grid-column: span 2;
background: rgba(26,20,16,0.95) !important;
border: 1px solid rgba(201,168,76,0.2);
align-items:center;
gap:2.5rem;
padding: 2.8rem 3.5rem;
flex-direction:row;
}
.menu-featured .menu-emoji { font-size:3.5rem; }
.menu-featured .menu-name { font-size:1.7rem; }
.featured-badge {
position:absolute; top:1.5rem; right:2rem;
font-size:0.62rem; letter-spacing:0.2em; text-transform:uppercase;
color:var(–black); background:var(–gold);
padding:0.3rem 0.8rem;
}

/* EXPERIENCE */
.experience {
padding: 8rem 0;
background: var(–black);
position:relative;
overflow:hidden;
}
.exp-bg {
position:absolute;
left:0; top:0; bottom:0;
width:50%;
background-image: url(‘data:image/jpeg;base64,’);
background-size:cover;
background-position: center;
filter: brightness(0.12) saturate(0.4);
mask-image: linear-gradient(to left, transparent 0%, rgba(0,0,0,0.7) 50%, black 100%);
-webkit-mask-image: linear-gradient(to left, transparent 0%, rgba(0,0,0,0.7) 50%, black 100%);
}
.experience-layout {
display:grid;
grid-template-columns: 1fr 1.1fr;
gap:5rem;
align-items:start;
position:relative; z-index:2;
}
.exp-list { margin-top:2.5rem; }
.exp-item {
display:flex; gap:1.3rem;
padding:1.8rem 0;
border-bottom:1px solid rgba(201,168,76,0.08);
}
.exp-num {
font-family:‘Bebas Neue’,sans-serif;
font-size:1.8rem;
color:var(–gold);
opacity:0.35;
flex-shrink:0;
line-height:1;
}
.exp-content h4 {
font-family:‘Playfair Display’,serif;
font-size:1.15rem;
color:var(–cream);
margin-bottom:0.35rem;
}
.exp-content p { font-size:0.93rem; line-height:1.7; color:rgba(212,197,169,0.58); }
.exp-quote {
background: rgba(26,20,16,0.9);
border-left:3px solid var(–gold);
padding:2.8rem;
margin-bottom:1.8rem;
position:relative;
backdrop-filter:blur(8px);
}
.exp-quote::before {
content:’”’;
font-family:‘Playfair Display’,serif;
font-size:7rem;
color:rgba(201,168,76,0.08);
position:absolute;
top:-1.5rem; left:1.2rem;
line-height:1;
}
.exp-quote p {
font-family:‘Cormorant Garamond’,serif;
font-size:1.35rem;
font-style:italic;
line-height:1.6;
color:var(–cream);
position:relative; z-index:1;
}
.exp-quote cite {
display:block; margin-top:1rem;
font-size:0.75rem; letter-spacing:0.15em; text-transform:uppercase;
color:var(–gold); font-style:normal;
}
.hours-card {
background: rgba(14,11,7,0.92);
border:1px solid rgba(201,168,76,0.15);
padding:2rem 2.5rem;
backdrop-filter:blur(8px);
}
.hours-title {
font-family:‘Bebas Neue’,sans-serif;
font-size:1.1rem; letter-spacing:0.15em;
color:var(–gold); margin-bottom:1rem;
}
.hours-row {
display:flex; justify-content:space-between;
padding:0.55rem 0;
border-bottom:1px solid rgba(201,168,76,0.06);
font-size:0.93rem;
}
.hours-row:last-child { border-bottom:none; }
.hours-day { color:rgba(212,197,169,0.65); }
.hours-time { color:var(–cream); font-weight:600; }
.closed { color:#c0392b; }

/* LOCATION */
.location {
padding:8rem 0;
background:var(–deep);
position:relative;
overflow:hidden;
}
.location-bg {
position:absolute; inset:0;
background-image: url(‘data:image/jpeg;base64,’);
background-size:cover;
background-position:center 10%;
filter:brightness(0.06) saturate(0.2);
}
.location-grid {
display:grid;
grid-template-columns:1.2fr 1fr;
gap:5rem;
align-items:start;
position:relative; z-index:2;
}
.map-box {
background:rgba(26,20,16,0.9);
border:1px solid rgba(201,168,76,0.18);
height:420px;
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
position:relative;
overflow:hidden;
backdrop-filter:blur(8px);
}
.map-box::before {
content:’’;
position:absolute; inset:0;
background:
linear-gradient(rgba(201,168,76,0.025) 1px, transparent 1px),
linear-gradient(90deg, rgba(201,168,76,0.025) 1px, transparent 1px);
background-size:50px 50px;
}
.map-pin { font-size:3rem; margin-bottom:1rem; position:relative; z-index:1; animation:bounce 2.5s ease-in-out infinite; }
@keyframes bounce { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-12px); } }
.map-label {
font-size:1rem; color:var(–text);
text-align:center; position:relative; z-index:1;
padding:0 2.5rem; line-height:1.7;
}
.map-btn {
margin-top:1.5rem;
background:var(–gold); color:var(–black);
padding:0.7rem 1.8rem;
font-family:‘Crimson Pro’,serif;
font-size:0.88rem; font-weight:700;
letter-spacing:0.1em; text-transform:uppercase;
text-decoration:none; position:relative; z-index:1;
transition:background 0.3s;
}
.map-btn:hover { background:var(–gold-light); }
.contact-block {
padding:1.8rem 0;
border-bottom:1px solid rgba(201,168,76,0.08);
}
.contact-block:last-child { border-bottom:none; }
.contact-label {
font-size:0.67rem; letter-spacing:0.3em; text-transform:uppercase;
color:var(–gold); margin-bottom:0.45rem; display:block;
}
.contact-value {
font-family:‘Playfair Display’,serif;
font-size:1.1rem; color:var(–cream); line-height:1.5;
}
.contact-value a { color:var(–cream); text-decoration:none; transition:color 0.3s; }
.contact-value a:hover { color:var(–gold); }

/* RESERVE */
.reservation {
padding:8rem 0;
position:relative;
overflow:hidden;
text-align:center;
}
.res-bg {
position:absolute; inset:0;
background-image: url(‘data:image/jpeg;base64,’);
background-size:cover;
background-position:center;
filter:brightness(0.22) saturate(0.6);
}
.res-overlay {
position:absolute; inset:0;
background: linear-gradient(135deg, rgba(10,8,5,0.7), rgba(139,26,26,0.15), rgba(10,8,5,0.7));
}
.res-inner {
position:relative; z-index:2;
max-width:780px; margin:0 auto;
}
.orn-line {
display:flex; align-items:center; justify-content:center;
gap:1.2rem; margin-bottom:2rem;
}
.orn-line::before, .orn-line::after {
content:’’; width:100px; height:1px;
background:linear-gradient(to right, transparent, rgba(201,168,76,0.7));
}
.orn-line::after { background:linear-gradient(to left, transparent, rgba(201,168,76,0.7)); }
.orn-diamond { width:7px; height:7px; background:var(–gold); transform:rotate(45deg); }
.reservation .section-title { font-size:clamp(2.4rem,6vw,4.2rem); margin-bottom:1.4rem; }
.reservation p { font-size:1.15rem; line-height:1.7; color:rgba(212,197,169,0.72); margin-bottom:2.8rem; }
.res-btns { display:flex; gap:1.2rem; justify-content:center; flex-wrap:wrap; margin-bottom:1.8rem; }
.res-note { font-size:0.82rem; color:rgba(212,197,169,0.38); letter-spacing:0.1em; }

/* FOOTER */
footer {
background:var(–deep);
border-top:1px solid rgba(201,168,76,0.12);
padding:4rem 0 2rem;
}
.footer-grid {
display:grid; grid-template-columns:2fr 1fr 1fr;
gap:4rem; margin-bottom:3rem;
}
.footer-brand .nav-logo { font-size:1.9rem; display:block; margin-bottom:0.9rem; }
.footer-brand p { font-size:0.92rem; line-height:1.7; color:rgba(212,197,169,0.48); max-width:280px; }
.footer-col h5 {
font-family:‘Bebas Neue’,sans-serif;
font-size:0.95rem; letter-spacing:0.22em;
color:var(–gold); margin-bottom:1.1rem;
}
.footer-col ul { list-style:none; }
.footer-col ul li { padding:0.32rem 0; }
.footer-col ul li a { color:rgba(212,197,169,0.5); text-decoration:none; font-size:0.92rem; transition:color 0.3s; }
.footer-col ul li a:hover { color:var(–gold); }
.footer-bottom {
